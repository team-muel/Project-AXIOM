# GCP VM AXIOM safe unattended sweep environment
AXIOM_BASE_URL=http://127.0.0.1:3100
AXIOM_MCP_BASE_URL=http://127.0.0.1:3210
AXIOM_NAMESPACE=axiom
AXIOM_OPERATOR_SOURCE=gcpCompute
AXIOM_OPERATOR_JOB_LIMIT=5
AXIOM_OPERATOR_WINDOW_HOURS=24
AXIOM_OPERATOR_PROJECTION_DIR=/opt/axiom/outputs/_system/operator-summary
AXIOM_OPERATOR_SWEEP_DIR=/opt/axiom/outputs/_system/operator-sweep
AXIOM_OPERATOR_INCIDENT_DIR=/opt/axiom/outputs/_system/operator-sweep/incident-drafts
# Optional if routes or MCP are protected by an upstream proxy
# AXIOM_OPERATOR_TOKEN=<optional-bearer-token>