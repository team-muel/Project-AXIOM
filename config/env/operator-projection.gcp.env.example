# GCP VM AXIOM operator projection environment
AXIOM_BASE_URL=http://127.0.0.1:3100
AXIOM_NAMESPACE=axiom
AXIOM_OPERATOR_SOURCE=gcpCompute
AXIOM_OPERATOR_JOB_LIMIT=5
AXIOM_OPERATOR_WINDOW_HOURS=24
AXIOM_OPERATOR_PROJECTION_DIR=/opt/axiom/outputs/_system/operator-summary
# Optional if the AXIOM app routes are protected by an upstream proxy or future auth layer
# AXIOM_OPERATOR_TOKEN=<optional-bearer-token>