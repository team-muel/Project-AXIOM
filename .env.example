PORT=3100
MCP_HTTP_PORT=3210
# Optional bearer token for AXIOM HTTP MCP routes.
# When set, callers must send Authorization: Bearer <token> to /mcp/* and /tools/list.
MCP_WORKER_AUTH_TOKEN=
LOG_LEVEL=info
OUTPUT_DIR=outputs
LOG_DIR=logs
MAX_RETRIES=2
PYTHON_BIN=python
# Symbolic render accepts SoundFont files supported by FluidSynth, typically .sf2 or .sf3.
# Adopted default: MuseScore_General.sf3. Keep default.sf2 only as the benchmark baseline.
SOUNDFONT_PATH=assets/soundfonts/MuseScore_General.sf3
FFMPEG_BIN=ffmpeg
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OVERSEER_AUTO_ENABLED=true
OVERSEER_INTERVAL_MS=600000
AUTONOMY_ENABLED=true
AUTONOMY_SCHEDULER_ENABLED=true
AUTONOMY_SCHEDULER_POLL_MS=30000
AUTONOMY_SCHEDULER_INTERVAL_MS=0
AUTONOMY_SCHEDULER_TIME=10:30
AUTONOMY_SCHEDULER_TIMEZONE=Asia/Seoul
AUTONOMY_MAX_ATTEMPTS_PER_DAY=2
AUTONOMY_STALE_LOCK_MS=3600000
AUTONOMY_AUTO_CLEAR_STALE_LOCKS=true
RETRY_BACKOFF_MS=2000
MUSICGEN_TIMEOUT_MS=1800000
STRUCTURE_RERANKER_SHADOW_ENABLED=false
STRUCTURE_RERANKER_SHADOW_SNAPSHOT=
# Reuses the shadow snapshot above and only promotes the narrow string_trio symbolic lane.
STRUCTURE_RERANKER_PROMOTION_ENABLED=false

# Optional shared gcpCompute operator defaults for bootstrap and docs.
AXIOM_GCPCOMPUTE_HOST=fancy@34.56.232.61
AXIOM_GCPCOMPUTE_SHARED_RUNTIME_DIR=/opt/muel/shared-mcp-runtime
AXIOM_GCPCOMPUTE_SHARED_HEALTH_URL=https://34.56.232.61.sslip.io/mcp/health
